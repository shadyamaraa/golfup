{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UB Golf Kitchen",
  "version": "0.1.0",
  "identifier": "club.ubgolf.kitchen",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "https://ubgolf.club/#/kitchen",
        "title": "UB Golf — Гал тогоо",
        "width": 460,
        "height": 760,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
