{
  "functions": {
    "source": "functions"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
      },
      {
        "source": "/version.json",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store" }]
      },
      {
        "source": "/manifest.webmanifest",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ],
    "rewrites": [
      {
        "source": "/api/mtbogd/**",
        "function": "mtbogdProxy"
      },
      {
        "source": "/api/admin-login",
        "function": "adminLogin"
      },
      {
        "source": "/api/kitchen-login",
        "function": "kitchenLogin"
      },
      {
        "source": "/api/cancel-booking",
        "function": "cancelGameBooking"
      },
      {
        "source": "/api/sync-players",
        "function": "syncBookingPlayers"
      },
      {
        "source": "/api/qpay/invoice",
        "function": "qpayCreateInvoice"
      },
      {
        "source": "/api/qpay/callback",
        "function": "qpayCallback"
      },
      {
        "source": "/api/qpay/check",
        "function": "qpayCheckPayment"
      },
      {
        "source": "/api/mtbogd-webhook",
        "function": "mtbogdWebhook"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
